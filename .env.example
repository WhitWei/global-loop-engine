# Global Loop Engine — Environment Configuration
# =================================================
# Copy this file to .env and customize as needed:
#   cp .env.example .env

# Database path for LangGraph checkpoints
# Default: ~/.loop-engine/loop_checkpoints.db
LOOP_ENGINE_DB_PATH=

# Maximum retry attempts before human approval
# Default: 3
MAX_RETRIES=

# Minimum delta between retries to consider progress (0.0-1.0)
# Default: 0.02
EPSILON_PASS_RATE_DELTA=

# Maximum feedback history entries to retain in context
# Default: 3
MAX_FEEDBACK_HISTORY=

# Maximum diff output length in characters
# Default: 500
MAX_DIFF_LENGTH=

# Maximum error output length in characters
# Default: 500
MAX_ERROR_OUTPUT_LENGTH=

# Logger name
# Default: global_loop_engine
LOGGER_NAME=

# Default test directory for integrity checking
# Default: ./tests
TESTS_DIR_DEFAULT=
